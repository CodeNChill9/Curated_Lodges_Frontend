# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────
# Get this from MongoDB Atlas → your cluster → "Connect" → "Drivers"
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/curated_lodges?retryWrites=true&w=majority

# ── Google Drive (Service Account) ───────────────────────────
# 1. Go to console.cloud.google.com → Create project
# 2. Enable "Google Drive API"
# 3. IAM & Admin → Service Accounts → Create service account
# 4. Keys tab → Add Key → JSON → download the file
# 5. Copy client_email and private_key from the downloaded JSON below
# 6. Share your target Drive folder with the service account email
#    (give it "Editor" access so it can upload files)

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private_key value exactly as it appears in the JSON file.
# Keep the -----BEGIN/END----- lines. Newlines inside should be literal \n.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# The ID of the Google Drive folder where uploads will be stored.
# Open the folder in Drive → copy the ID from the URL:
# https://drive.google.com/drive/folders/<FOLDER_ID_HERE>
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
